<?xml version="1.0" encoding="utf-8"?>
<!--
  Day (light) palette. Names mirror the dark palette in values-night/ so
  every layout that references @color/bg_dark etc. still resolves without
  edits — it just picks up a light value when the system (or AppCompat-
  Delegate override) is in day mode.
-->
<resources>
    <color name="black">#FF000000</color>
    <color name="white">#FFFFFFFF</color>

    <!-- Background hierarchy (LIGHT) -->
    <color name="bg_dark">#F8FAFC</color>         <!-- page background -->
    <color name="bg_surface">#FFFFFF</color>       <!-- elevated surface -->
    <color name="bg_card">#F1F5F9</color>          <!-- card fill -->
    <color name="bg_card_stroke">#CBD5E1</color>   <!-- card outline -->
    <color name="bg_elevated">#E2E8F0</color>      <!-- deeper elevation -->
    <color name="bg_input">#F1F5F9</color>         <!-- input field fill -->

    <!-- Accent colors (darkened for AA contrast on light bg) -->
    <color name="accent_purple">#7C3AED</color>
    <color name="accent_purple_dim">#1A7C3AED</color>
    <color name="accent_green">#059669</color>
    <color name="accent_green_dim">#1A059669</color>
    <color name="accent_red">#DC2626</color>
    <color name="accent_red_dim">#1ADC2626</color>
    <color name="accent_blue">#2563EB</color>
    <color name="accent_amber">#D97706</color>
    <color name="accent_cyan">#0891B2</color>

    <!-- Text colors -->
    <color name="text_primary">#0F172A</color>     <!-- near-black -->
    <color name="text_secondary">#475569</color>   <!-- slate -->
    <color name="text_tertiary">#94A3B8</color>    <!-- muted slate -->

    <!-- Status bar -->
    <color name="status_bar">#E2E8F0</color>
</resources>
