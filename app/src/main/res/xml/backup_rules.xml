<?xml version="1.0" encoding="utf-8"?>
<!--
    allowBackup is set to false in the manifest, so this is a defense-in-depth
    measure: even if backup is force-enabled, exclude credential storage and
    the local Room database to prevent leakage of PII / financial data.
-->
<full-backup-content>
    <exclude domain="sharedpref" path="angel_one_credentials.xml" />
    <exclude domain="sharedpref" path="wealthflow_secure_prefs.xml" />
    <exclude domain="database" path="wealth_database" />
    <exclude domain="database" path="wealth_database-journal" />
</full-backup-content>
